# ── LLM ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_CODE_MODEL=claude-sonnet-4-6

# ── Target repository ───────────────────────────────────
REPO_DIR=/path/to/your/project
BASE_BRANCH=main
TEST_CMD=pytest --tb=short -q
PROJECT_DESCRIPTION=a Python web application

# ── Task source (Trello) ────────────────────────────────
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here
BOARD_ID=your_trello_board_id_here
TRELLO_LIST_ID=your_todo_list_id_here
# TRELLO_REVIEW_LIST_ID=optional_review_list_id

# ── Pull requests (choose ONE provider) ─────────────────
# GitHub:
GH_TOKEN=your_github_personal_access_token
GH_REPO=owner/repo

# Bitbucket (alternative):
# WORKSPACE=your_bitbucket_workspace_slug
# REPO=your_bitbucket_repo_slug
# BB_USER=your_atlassian_email
# BB_TOKEN=your_bitbucket_app_password

# ── Limits ───────────────────────────────────────────────
CODER_TIMEOUT=1800

# ── Git author for AI commits ───────────────────────────
GIT_AUTHOR_NAME=AI Agent
GIT_AUTHOR_EMAIL=ai-agent@noreply.local
